<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Thumbnail Image -->
        <androidx.cardview.widget.CardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/ivWordThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_camera_illustration1"
                android:contentDescription="Vocabulary image" />

        </androidx.cardview.widget.CardView>

        <!-- Word Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvWordTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vocabulary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/vocab_text_dark" />

            <TextView
                android:id="@+id/tvWordIPA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/vəˈkæbjəleri/"
                android:textSize="13sp"
                android:textColor="@color/vocab_purple"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvWordMeaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="từ vựng, vốn từ"
                android:textSize="14sp"
                android:textColor="@color/vocab_text_gray"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>