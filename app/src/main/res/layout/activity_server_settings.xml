<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cấu hình Backend Server"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCurrentBaseUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Server hiện tại:"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/edtBaseUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="Ví dụ: http://192.168.1.5:8000/"
            android:inputType="textUri"
            android:singleLine="true" />

        <Button
            android:id="@+id/btnSaveServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Lưu server URL" />

        <Button
            android:id="@+id/btnUseEmulator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Dùng emulator: http://10.0.2.2:8000/" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Điện thoại thật: nhập IP laptop, ví dụ http://192.168.1.5:8000/\nBackend phải chạy: uvicorn main:app --host 0.0.0.0 --port 8000 --reload"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Quay lại" />

    </LinearLayout>
</ScrollView>