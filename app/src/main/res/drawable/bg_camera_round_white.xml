<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#20000000">
    <item>
        <layer-list>
            <!-- 1. Viền màu kem ngoài cùng -->
            <item>
                <shape android:shape="oval">
                    <solid android:color="@color/cream_500" />
                </shape>
            </item>

            <!-- 2. Viền xám nằm liền kề (Thay cho màu đen) -->
            <item android:top="4dp" android:left="4dp" android:right="4dp" android:bottom="4dp">
                <shape android:shape="oval">
                    <solid android:color="@color/warm_gray" />
                </shape>
            </item>

            <!-- 3. Nền trắng chính bên trong -->
            <item android:top="8dp" android:left="8dp" android:right="8dp" android:bottom="8dp">
                <shape android:shape="oval">
                    <solid android:color="@color/white" />
                </shape>
            </item>
        </layer-list>
    </item>
</ripple>